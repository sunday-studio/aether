{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Aether",
	"version": "0.1.1",
	"identifier": "com.cas.aether",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Aether",
				"width": 1500,
				"height": 1000
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"macOS": {
			"entitlements": "null",
			"signingIdentity": "null"
		},
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
