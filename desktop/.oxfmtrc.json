{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"sortTailwindcss": {
		"stylesheet": "./src/app.css",
		"functions": ["clsx", "cn", "cx", "tv"]
	},
	"arrowParens": "avoid",
	"bracketSpacing": true,
	"endOfLine": "lf",
	"jsxBracketSameLine": false,
	"jsxSingleQuote": true,
	"printWidth": 100,
	"proseWrap": "preserve",
	"semi": true,
	"singleQuote": true,
	"tabWidth": 2,
	"useTabs": true,
	"trailingComma": "all",
	"importOrder": [
		"^(react/(.*)$)|^(react$)",
		"<THIRD_PARTY_MODULES>",
		"~/sdk/*",
		"~/context/*",
		"~/features/*",
		"~/router/*",
		"~/services/*",
		"~/store/*",
		"~/styles/*",
		"~/utils/*",
		"~/components/*",
		"~/types/*",
		"~/hooks/*",
		"~/lib/*",
		"~/pages/*",
		"~/public/*",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,
	"importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
	"sortPackageJson": false,
	"ignorePatterns": [
		"dist/**",
		"node_modules/**",
		"src/aether-sdk/**",
		"src/openapi/**",
		"src-tauri/gen/**",
		"src-tauri/target/**"
	]
}
