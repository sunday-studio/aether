{
  "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "jsxBracketSameLine": false,
  "jsxSingleQuote": true,
  "printWidth": 100,
  "proseWrap": "preserve",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "importOrder": [
    "^(react/(.*)$)|^(react$)",
    "<THIRD_PARTY_MODULES>",
    "~/sdk/*",
    "~/context/*",
    "~/features/*",
    "~/router/*",
    "~/services/*",
    "~/store/*",
    "~/styles/*",
    "~/utils/*",
    "~/components/*",
    "~/types/*",
    "~/hooks/*",
    "~/lib/*",
    "~/pages/*",
    "~/public/*",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "tailwindStylesheet": "./src/index.css",
  "tailwindFunctions": ["clsx", "cn", "cx", "clsx"]
}
